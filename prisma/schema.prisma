generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id         String      @id @default(cuid())
  name       String
  address    String
  phone      String?
  email      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  quotations Quotation[]
}

model Product {
  id                String          @id @default(cuid())
  name              String
  description       String          @default("")
  category          String          @default("General")
  sectionCode       String          @default("A")
  defaultRate       Decimal         @db.Decimal(14, 2)
  unit              String          @default("Nos")
  warranty          String          @default("")
  templateText      String?         @default("")
  templateVariables String[]
  imagePath         String?
  imageText         String?
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  items             QuotationItem[]

  @@index([name])
  @@index([category])
  @@index([sectionCode])
}

model CompanySettings {
  id             String   @id @default(cuid())
  companyName    String   @default("Your Company")
  logoUrl        String?
  address        String   @default("")
  gstin          String   @default("")
  phones         String   @default("")
  email          String   @default("")
  signatureUrl   String?
  defaultGstRate Decimal  @default(18) @db.Decimal(5, 2)
  terms          String   @default("")
  paymentTerms   String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Quotation {
  id                    String          @id @default(cuid())
  quoteNumber           String          @unique
  title                 String          @default("")
  customerId            String
  date                  DateTime
  gstPercent            Decimal         @db.Decimal(5, 2)
  subtotal              Decimal         @db.Decimal(14, 2)
  gstAmount             Decimal         @db.Decimal(14, 2)
  grandTotal            Decimal         @db.Decimal(14, 2)
  amountInWords         String          @default("")
  notes                 String          @default("")
  terms                 String          @default("")
  paymentTerms          String          @default("")
  projectSpecifications Json
  sections              Json            @default("[]")
  isDraft               Boolean         @default(false)
  deletedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  customer              Customer        @relation(fields: [customerId], references: [id])
  items                 QuotationItem[]

  @@index([quoteNumber])
  @@index([date])
  @@index([deletedAt])
}

model QuotationItem {
  id             String    @id @default(cuid())
  quotationId    String
  section        String
  serialNo       Int
  category       String    @default("General")
  description    String
  warranty       String    @default("")
  qty            Decimal   @db.Decimal(14, 3)
  unit           String
  rate           Decimal   @db.Decimal(14, 2)
  amount         Decimal   @db.Decimal(14, 2)
  imageUrl       String?
  imageText      String?
  productId      String?
  variableValues Json      @default("{}")
  title          String    @default("")
  isCustom       Boolean   @default(false)
  product        Product?  @relation(fields: [productId], references: [id])
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([productId])
}

model ProductCatalog {
  id             String      @id @default(cuid())
  companyType    CompanyType
  category       String
  code           String?
  name           String
  description    String
  specifications Json?       @default("{}")
  unitPrice      Decimal     @db.Decimal(14, 2)
  unit           String?     @default("Nos")
  source         String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyType])
  @@index([category])
  @@index([name])
  @@index([code])
}

enum UserRole {
  ADMIN
  USER
}

enum CompanyType {
  MR_SWIMMING_POOLS
  KLEAN_TECH_SYSTEMS
  MR_ACADEMY
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  invoiceDate     DateTime
  customerName    String
  customerAddress String
  customerGST     String?
  customerMobile  String?
  items           Json     // Array of { description, unitPrice, qty, total }
  subTotal        Decimal  @db.Decimal(14, 2)
  cgstPercent     Decimal  @default(9) @db.Decimal(5, 2)
  sgstPercent     Decimal  @default(9) @db.Decimal(5, 2)
  cgstAmount      Decimal  @db.Decimal(14, 2)
  sgstAmount      Decimal  @db.Decimal(14, 2)
  roundOff        Decimal  @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal  @db.Decimal(14, 2)
  amountInWords   String
  bankDetails     String?
  isDraft         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceNumber])
  @@index([invoiceDate])
}
