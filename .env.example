# PostgreSQL connection string (must match a real running Postgres)
#
# If you use Docker in this repo:
#   docker compose up -d
#   Then use the URL below as-is:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/smartquotation?schema=public"
#
# Or your own server (replace USER, PASSWORD, host, port, DB name):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smartquotation?schema=public"

# Iron session — must be at least 32 characters in production
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Optional: override seed admin password (default in seed script documented in README)
# SEED_ADMIN_PASSWORD="YourSecurePassword"
